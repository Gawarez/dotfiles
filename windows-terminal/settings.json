{
    "actions": 
    [
        {
            "command": "openTabColorPicker",
            "id": "User.openTabColorPicker",
            "keys": "ctrl+alt+d"
        },

        {
            "command": "openTabRenamer",
            "id": "User.openTabRenamer",
            "keys": "ctrl+alt+r"
        }
    ],

    "copyFormatting": "none",
    "copyOnSelect": false,
    "defaultProfile": "{}",
